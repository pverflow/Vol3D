  "type": "module",
  "scripts": {
    "version:sync": "node ./scripts/sync-version.mjs",
    "version:check": "node ./scripts/sync-version.mjs --check",
    "dev": "vite",
    "build": "npm run version:sync && tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run version:sync && tauri dev",
    "tauri:build": "npm run version:sync && tauri build",
    "tauri:build:nsis": "npm run version:sync && tauri build",
    "release:windows:cert": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/new-self-signed-cert.ps1",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/build-release.ps1"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.4.3",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.1",
    "typescript": "^5.6.2",
    "vite": "^6.0.0"
  }
}
