{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vol3D",
  "version": "1.0.0",
  "identifier": "com.vol3d.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vol3D",
        "width": 1600,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "publisher": "Vol3D",
    "shortDescription": "Desktop 3D seamless volume noise texture generator.",
    "longDescription": "Vol3D is a desktop 3D volume texture and seamless noise generator for game development, shaders, and VFX workflows. This packaging setup builds a Windows executable and NSIS installer and supports local self-signed release signing.",
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "./windows/sign-vol3d.ps1",
          "-BinaryPath",
          "%1"
        ]
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "Vol3D",
        "installerIcon": "./icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  }
}


